# Canva App Configuration
# Copy this to .env and fill in values from your Canva Developer Portal

CANVA_FRONTEND_PORT=8080
CANVA_APP_ID=                # Your app ID from Developer Portal -> Settings
CANVA_APP_ORIGIN=            # Your app origin from Developer Portal -> Settings -> Security
CANVA_HMR_ENABLED=FALSE      # Set to TRUE for Hot Module Replacement during development
