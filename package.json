{
  "name": "canup",
  "version": "0.1.0",
  "description": "Managed backend for Canva Apps — CLI & React components",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparkncraft/canup.git"
  },
  "keywords": [
    "canva",
    "canva-apps",
    "serverless",
    "lambda",
    "cli",
    "deploy",
    "react"
  ],
  "type": "module",
  "bin": {
    "canup": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "changeset": "changeset"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "ora": "^9.3.0",
    "tsx": "^4.19.4",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@canva/app-ui-kit": ">=5.0.0 <7.0.0",
    "@canva/platform": "*",
    "@canva/user": "*",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@canva/app-ui-kit": {
      "optional": true
    },
    "@canva/platform": {
      "optional": true
    },
    "@canva/user": {
      "optional": true
    }
  },
  "devDependencies": {
    "@canva/app-ui-kit": "^5.7.0",
    "@canva/platform": "^2.2.0",
    "@canva/user": "^2.2.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-oxc": "^0.1.3",
    "@tanstack/react-query": "^5.96.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.0.0",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "tsdown": "^0.21.4",
    "type-fest": "^5.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0"
  }
}
