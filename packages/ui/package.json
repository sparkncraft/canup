{
  "name": "@canup/ui",
  "version": "0.2.0",
  "description": "React components for Canva apps with a managed CanUp backend — actions, credits, and monetization status.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparkncraft/canup.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "canva",
    "canva-apps",
    "react",
    "components",
    "monetization",
    "credits"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:build": "publint --strict && attw --pack . --profile esm-only",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "imports": {
    "#test/*": "./test/*"
  },
  "sideEffects": false,
  "dependencies": {
    "@tanstack/react-query": "^5.96.0",
    "eventsource": "^4.1.0"
  },
  "devDependencies": {
    "@canup/contracts": "^0.2.0",
    "@canva/app-i18n-kit": "^1.2.0",
    "@canva/app-ui-kit": "^5.9.0",
    "@canva/platform": "^2.2.2",
    "@canva/user": "^2.2.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.12.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intl": "^7.1.11",
    "size-limit": "^12.0.1"
  },
  "peerDependencies": {
    "@canva/app-i18n-kit": ">=1.2.0",
    "@canva/app-ui-kit": ">=5.0.0 <6.0.0",
    "@canva/platform": ">=2.0.0",
    "@canva/user": ">=2.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-intl": ">=6.6.8 <=7.1.11"
  },
  "peerDependenciesMeta": {
    "@canva/app-i18n-kit": {
      "optional": true
    }
  }
}
