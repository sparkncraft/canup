{
  "name": "@canup/cli",
  "version": "0.2.0",
  "description": "Command-line tool to scaffold, deploy, and manage Canva app backends on CanUp.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparkncraft/canup.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "canva",
    "canva-apps",
    "serverless",
    "lambda",
    "cli",
    "deploy"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:build": "publint --strict && attw --pack . --profile esm-only",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "canup": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "imports": {
    "#test/*": "./test/*"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@canup/contracts": "^0.2.0",
    "@types/node": "^22.13.4",
    "type-fest": "^5.5.0"
  }
}
