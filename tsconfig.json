{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "jsx": "react-jsx"
  },
  "include": ["packages/*/src"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/dist"]
}
